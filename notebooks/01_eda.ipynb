# ============================================================
# IMPORT LIBRARIES
# ============================================================

import requests
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# ============================================================
# GITHUB API CONFIGURATION
# ============================================================

OWNER = "pandas-dev"
REPO = "pandas"

BASE_URL = f"https://api.github.com/repos/{OWNER}/{REPO}/issues"

# ============================================================
# COLLECT ISSUES DATA
# ============================================================

all_issues = []

# Collect around 200 rows
for page in range(1, 3):

    url = (
        f"{BASE_URL}"
        f"?state=all&per_page=100&page={page}"
    )

    response = requests.get(url)

    if response.status_code != 200:
        print(f"Error collecting page {page}")
        break

    data = response.json()

    if len(data) == 0:
        break

    all_issues.extend(data)

    print(f"Collected page {page}")

# ============================================================
# CONVERT TO DATAFRAME
# ============================================================

df = pd.DataFrame(all_issues)

print("Raw dataset shape:")
print(df.shape)

# ============================================================
# SAVE RAW DATASET
# ============================================================

df.to_csv("../data/raw/issues_raw.csv", index=False)

print("Raw dataset saved.")

# ============================================================
# FILTER ONLY TRUE ISSUES
# REMOVE PULL REQUESTS
# ============================================================

issues_df = df[df["pull_request"].isna()].copy()

print("Actual issues shape:")
print(issues_df.shape)

# ============================================================
# SELECT IMPORTANT COLUMNS
# ============================================================

issues_df = issues_df[
    [
        "id",
        "number",
        "title",
        "state",
        "created_at",
        "closed_at",
        "comments"
    ]
]

# ============================================================
# CONVERT DATETIME COLUMNS
# ============================================================

issues_df["created_at"] = pd.to_datetime(
    issues_df["created_at"]
)

issues_df["closed_at"] = pd.to_datetime(
    issues_df["closed_at"]
)

# ============================================================
# CREATE CLOSE DURATION FEATURE
# ============================================================

issues_df["close_duration_days"] = (
    issues_df["closed_at"] - issues_df["created_at"]
).dt.days

# ============================================================
# CREATE ISSUE STATUS FEATURE
# ============================================================

issues_df["is_closed"] = (
    issues_df["state"] == "closed"
).astype(int)

# ============================================================
# HANDLE MISSING VALUES
# ============================================================

issues_df = issues_df.dropna(
    subset=["close_duration_days"]
)

# ============================================================
# SAVE CLEAN DATASET
# ============================================================

issues_df.to_csv(
    "../data/clean/dataset.csv",
    index=False
)

print("Clean dataset saved.")

# ============================================================
# DATASET OVERVIEW
# ============================================================

print("\nDataset Shape:")
print(issues_df.shape)

print("\nFirst 5 Rows:")
print(issues_df.head())

print("\nDataset Info:")
print(issues_df.info())

# ============================================================
# CHECK MISSING VALUES
# ============================================================

print("\nMissing Values:")
print(issues_df.isnull().sum())

# ============================================================
# DESCRIPTIVE STATISTICS
# ============================================================

print("\nDescriptive Statistics:")
print(issues_df.describe())

# ============================================================
# VISUALIZATION 1
# DISTRIBUTION OF ISSUE CLOSING DURATION
# ============================================================

plt.figure(figsize=(10, 5))

sns.histplot(
    issues_df["close_duration_days"],
    bins=30
)

plt.title("Distribution of Issue Closing Duration")
plt.xlabel("Closing Duration (Days)")
plt.ylabel("Frequency")

plt.show()

# ============================================================
# VISUALIZATION 2
# ISSUE STATUS COUNT
# ============================================================

plt.figure(figsize=(6, 4))

issues_df["state"].value_counts().plot(
    kind="bar"
)

plt.title("Issue Status Count")
plt.xlabel("Issue State")
plt.ylabel("Count")

plt.show()

# ============================================================
# VISUALIZATION 3
# ISSUES CREATED OVER TIME
# ============================================================

issues_df["year_month"] = (
    issues_df["created_at"]
    .dt.to_period("M")
    .astype(str)
)

monthly_issues = (
    issues_df["year_month"]
    .value_counts()
    .sort_index()
)

plt.figure(figsize=(12, 5))

monthly_issues.plot()

plt.title("Issues Created Over Time")
plt.xlabel("Year-Month")
plt.ylabel("Number of Issues")

plt.xticks(rotation=45)

plt.show()

# ============================================================
# VARIABLE SELECTION
# ============================================================

variable_selection = pd.DataFrame({
    "Variable": [
        "is_closed",
        "close_duration_days",
        "comments"
    ],
    "Statistical Usage": [
        "Bernoulli Estimation",
        "Confidence Interval & Hypothesis Testing",
        "Poisson Analysis"
    ]
})

print("\nVariable Selection:")
print(variable_selection)

